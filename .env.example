# ─────────────────────────────────────────────────────────────
# ODDY.AI — Environment Variables
# Copy to .env and fill in your keys. NEVER commit .env.
# ─────────────────────────────────────────────────────────────

PORT=3000
NODE_ENV=development

# Redis
REDIS_URL=redis://localhost:6379
CACHE_DEFAULT_TTL_S=60

# Database (optional for V1)
DATABASE_URL=postgresql://user:password@localhost:5432/oddy

# ── API PROVIDERS ─────────────────────────────────────────────

# Synthesis — Kalshi leaderboard + profile P&L
# https://api.synthesis.trade/docs/api-reference/
SYNTHESIS_API_KEY=

# Tatum — Polymarket top traders
# https://docs.tatum.io/reference/getpredictiontoptradersv4
TATUM_API_KEY=

# Radion — Polymarket ROI % + win rate (stub until live)
# https://docs.radion.app/api-reference/
RADION_API_KEY=

# Predexon — Polymarket wallet PnL, positions, leaderboard (Dev/Pro tier required)
# https://docs.predexon.com/
PREDEXON_API_KEY=

# PolyRouter — Kalshi/Polymarket fallback (server currently down)
# https://docs.polyrouter.io/
POLYROUTER_API_KEY=
